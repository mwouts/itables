{
  "name": "itables_for_streamlit",
  "version": "0.2.0",
  "private": true,
  "dependencies": {
    "@streamlit/component-v2-lib": "^0.2.0",
    "dt_for_itables": "file:../dt_for_itables"
  },
  "devDependencies": {
    "esbuild": "^0.25.9",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build:js": "esbuild src/index.tsx --bundle --minify --format=esm --outdir=../../src/itables/itables_for_streamlit",
    "build:css": "esbuild src/index.css --bundle --outdir=../../src/itables/itables_for_streamlit",
    "build": "npm run build:js && npm run build:css",
    "typecheck": "tsc --noEmit"
  }
}
