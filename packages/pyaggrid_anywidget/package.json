{
	"scripts": {
		"dev": "npm run build -- --sourcemap=inline --watch",
		"build:js": "esbuild js/widget.js --format=esm --bundle --minify --outdir=../../python/pyaggrid/src/pyaggrid/widget/static",
		"build:css": "esbuild js/widget.css --bundle --minify --outdir=../../python/pyaggrid/src/pyaggrid/widget/static",
