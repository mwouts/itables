{
	"scripts": {
		"dev": "npm run build -- --sourcemap=inline --watch",
		"build:js": "esbuild js/widget.ts --format=esm --bundle --minify --outdir=../../src/pydatatables/widget/static",
		"build:css": "esbuild js/widget.css --bundle --minify --outdir=../../src/pydatatables/widget/static",
		"build": "npm run build:js && npm run build:css",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"pydatatables": "file:../pydatatables"
	},
	"devDependencies": {
		"@anywidget/types": "^0.4.0",
		"esbuild": "^0.25.9",
		"typescript": "^6.0.3"
	}
}
