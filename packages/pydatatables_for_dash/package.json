{
  "name": "pydatatables_for_dash",
  "version": "0.2.0",
  "description": "PyDataTablesRenderers for Dash",
  "main": "build/index.js",
  "scripts": {
    "build:js": "webpack --mode production",
    "build:backends": "dash-generate-components src/lib/components pydatatables_for_dash -p package-info.json",
    "move": "mv pydatatables_for_dash/* ../../python/pydatatables/src/pydatatables_for_dash && rmdir pydatatables_for_dash",
    "build": "npm run build:js && npm run build:backends && npm run move"
  },
  "author": "Marc Wouts <marc.wouts@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "pydatatables": "file:../pydatatables"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@plotly/dash-component-plugins": "^1.2.3",
    "@plotly/webpack-dash-dynamic-import": "^1.3.0",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-docgen": "^5.4.3",
    "style-loader": "^4.0.0",
    "styled-jsx": "^5.1.7",
    "webpack-cli": "^7.0.2"
  },
  "engines": {
    "node": ">=8.11.0",
    "npm": ">=6.1.0"
  }
}
