# Stop everything if one command fails
set -e

# Install from sources
pip install ./python/itables_core "./python/pydatatables[all]" ./python/pyaggrid ./python/itables

# Open .md notebooks with the Notebook editor
mkdir -p ${HOME}/.jupyter/labconfig
cp binder/labconfig/* ${HOME}/.jupyter/labconfig

# Install a kernel called pydatatables
python -m ipykernel install --name pydatatables --user

# Use that kernel for the documentation notebooks
jupytext docs/*.md --set-kernel pydatatables
jupytext README.md --set-kernel pydatatables
